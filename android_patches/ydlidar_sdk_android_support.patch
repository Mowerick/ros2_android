new file mode 100644
index 0000000..1b9893b
--- /dev/null
+++ b/core/serial/impl/android/android_jni_serial.h
@@ -0,0 +1,170 @@
+#if defined(__ANDROID__)
+
+#ifndef SERIAL_IMPL_ANDROID_JNI_H
+#define SERIAL_IMPL_ANDROID_JNI_H
+
+#include <jni.h>
+#include <pthread.h>
+#include <string>
+#include <core/serial/serial.h>
+
+namespace ydlidar
+{
+  namespace core
+  {
+    namespace serial
+    {
+
+      /**
+       * Android JNI-based serial implementation for YDLIDAR SDK.
+       *
+       * This implementation routes all serial operations through JNI to Java's
+       * BufferedUsbSerialPort class, which uses mik3y/usb-serial-for-android
+       * to communicate with USB serial devices without kernel drivers.
+       *
+       * Architecture:
+       *   Serial::SerialImpl (this class)
+       *        ↓ JNI calls
+       *   UsbSerialBridge.kt
+       *        ↓
+       *   BufferedUsbSerialPort.kt (background reader + CircularByteBuffer)
+       *        ↓
+       *   UsbSerialPort (mik3y library)
+       *        ↓
+       *   Android USB Host API
+       *
+       * Key Operations:
+       *   - open()       → UsbSerialBridge.openDevice() → returns BufferedUsbSerialPort
+       *   - available()  → bufferedPort.available() (queries CircularByteBuffer)
+       *   - read()       → bufferedPort.read() (reads from CircularByteBuffer with timeout)
+       *   - write()      → bufferedPort.write() (direct USB write)
+       *   - flush()      → bufferedPort.flush() (clear buffer + purge USB buffers)
+       *
+       * Thread Safety:
+       *   - pthread_mutex protects read/write operations (matching unix_serial.cpp)
+       *   - JNI environment is thread-local (AttachCurrentThread per thread)
+       *
+       * Object Lifetime:
+       *   - Java BufferedUsbSerialPort reference is stored as global ref
+       *   - Global ref is released in close() to allow GC
+       */
+      class Serial::SerialImpl
+      {
+      public:
+        /**
+         * Constructor
+         *
+         * @param port Device identifier (e.g., "lidar_dev_bus_001_device_003")
+         * @param baudrate Baud rate (e.g., 512000 for YDLIDAR TG15)
+         * @param bytesize Data bits (5/6/7/8)
+         * @param parity Parity (none/odd/even/mark/space)
+         * @param stopbits Stop bits (1/1.5/2)
+         * @param flowcontrol Flow control (none/software/hardware)
+         */
+        explicit SerialImpl(const std::string &port,
+                            unsigned long baudrate,
+                            bytesize_t bytesize,
+                            parity_t parity,
+                            stopbits_t stopbits,
+                            flowcontrol_t flowcontrol);
+
+        virtual ~SerialImpl();
+
+        // Core I/O operations (MUST IMPLEMENT)
+        bool open();
+        void close();
+        bool isOpen() const;
+        size_t available();
+        size_t read(uint8_t *buf, size_t size);
+        size_t write(const uint8_t *data, size_t length);
+
+        // Timeout operations (IMPORTANT for YDLIDAR)
+        int waitfordata(size_t data_count, uint32_t timeout, size_t *returned_size);
+        bool waitReadable(uint32_t timeout);
+        void waitByteTimes(size_t count);
+
+        // Configuration operations (MUST IMPLEMENT)
+        bool setBaudrate(unsigned long baudrate);
+        bool setBytesize(bytesize_t bytesize);
+        bool setParity(parity_t parity);
+        bool setStopbits(stopbits_t stopbits);
+
+        // Buffer operations (MUST IMPLEMENT)
+        void flush();
+        void flushInput();
+        void flushOutput();
+
+        // Control signals (OPTIONAL - YDLIDAR doesn't use hardware flow control)
+        bool setFlowcontrol(flowcontrol_t flowcontrol);
+        bool setRTS(bool level);
+        bool setDTR(bool level);
+        bool getCTS();
+        bool getDSR();
+        bool getRI();
+        bool getCD();
+        bool waitForChange();
+        bool setBreak(bool level);
+        void sendBreak(int duration);
+
+        // Standard baud rate methods (used by SDK)
+        bool setStandardBaudRate(unsigned long baudrate);
+        bool setCustomBaudRate(unsigned long baudrate);
+
+        // Getters/setters
+        void setPort(const std::string &port);
+        std::string getPort() const;
+        void setTimeout(Timeout &timeout);
+        Timeout getTimeout() const;
+        unsigned long getBaudrate() const;
+        bytesize_t getBytesize() const;
+        parity_t getParity() const;
+        stopbits_t getStopbits() const;
+        flowcontrol_t getFlowcontrol() const;
+        uint32_t getByteTime();
+        Serial::SerialPortError getSystemError(int systemErrorCode) const;
+
+        // termios operations (not used on Android, return success)
+        bool setTermios(const void *tio);
+        bool getTermios(void *tio);
+
+        // Thread safety (locks for read/write operations)
+        int readLock();
+        int readUnlock();
+        int writeLock();
+        int writeUnlock();
+
+      private:
+        // Device information
+        std::string port_; // Device identifier (e.g., "lidar_dev_bus_001_device_003")
+        bool is_open_;
+
+        // Java object reference (BufferedUsbSerialPort instance)
+        jobject java_port_ref_; // Global reference to BufferedUsbSerialPort
+
+        // Serial configuration
+        Timeout timeout_;        // Read/write timeout settings
+        unsigned long baudrate_; // Baud rate
+        uint32_t byte_time_ns_;  // Time to transmit/receive one byte (nanoseconds)
+
+        parity_t parity_;           // Parity setting
+        bytesize_t bytesize_;       // Data bits (5/6/7/8)
+        stopbits_t stopbits_;       // Stop bits
+        flowcontrol_t flowcontrol_; // Flow control
+
+        // Note: No mutexes needed - Java CircularByteBuffer is thread-safe
+
+        // JNI environment helpers
+        JNIEnv *getJNIEnv();
+        void detachJNIEnv();
+
+        // Error tracking
+        mutable Serial::SerialPortError last_error_;
+      };
+
+    } // namespace serial
+  } // namespace core
+} // namespace ydlidar
+
+#endif // SERIAL_IMPL_ANDROID_JNI_H
+
+#endif // __ANDROID__
