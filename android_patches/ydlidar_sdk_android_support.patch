+      inline void infoh(const uint8_t *data, int size, const char *prefix = NULL)
+      {
+#ifdef __ANDROID__
+        if (!data || !size)
+          return;
+
+        // Build hex string
+        char buff[2048] = {0};
+        int offset = 0;
+        if (prefix)
+        {
+          offset = snprintf(buff, sizeof(buff), "%s", prefix);
+        }
+        for (int i = 0; i < size && offset < sizeof(buff) - 3; ++i)
+        {
+          offset += snprintf(buff + offset, sizeof(buff) - offset, "%02X", data[i]);
+        }
+        __android_log_print(ANDROID_LOG_INFO, "YDLidar_SDK", "%s", buff);
+#else
+        if (!data || !size)
+          return;
+        PRINT_TIME
+        printf("[info] ");
+        if (prefix)
+          printf(prefix);
+        for (int i = 0; i < size; ++i)
