 //调试
 inline void debug(char* fmt, ...)
 {
+#ifdef __ANDROID__
+  char buff[1024] = {0};
+  va_list ap;
+  va_start(ap, fmt);
+  vsnprintf(buff, sizeof(buff), fmt, ap);
+  va_end(ap);
+  __android_log_print(ANDROID_LOG_DEBUG, "YDLidar_SDK", "%s", buff);
+#else
   printf(GREEN); //设置绿色
   PRINT_TIME
   printf("[debug] ");
   FORMAT_STDOUT
   printf(COLOFF); //恢复默认颜色
   fflush(stdout);
+#endif
 }

