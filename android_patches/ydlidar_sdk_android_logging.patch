 inline void debugh(const uint8_t *data, int size, const char* prefix=NULL)
 {
+#ifdef __ANDROID__
+  if (!data || !size)
+    return;
+
+  // Build hex string
+  char buff[2048] = {0};
+  int offset = 0;
+  if (prefix) {
+    offset = snprintf(buff, sizeof(buff), "%s", prefix);
